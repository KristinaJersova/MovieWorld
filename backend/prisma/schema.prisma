generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["movie_world"]
}

model User {
  id        Int                @id @default(autoincrement())
  username  String             @unique
  email     String             @unique
  password  String
  role      String             @default("user")
  createdAt DateTime           @default(now())
  views     MovieViewHistory[]

  @@schema("movie_world")
}

model Director {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  movies Movie[]

  @@index([name], map: "idx_director_name")
  @@schema("movie_world")
}

model Actor {
  id     Int          @id @default(autoincrement())
  name   String       @unique
  movies MovieActor[]

  @@index([name], map: "idx_actor_name")
  @@schema("movie_world")
}

model Genre {
  id     Int          @id @default(autoincrement())
  name   String       @unique
  movies MovieGenre[]

  @@index([name], map: "idx_genre_name")
  @@schema("movie_world")
}

model Rating {
  id     Int           @id @default(autoincrement())
  rating Float
  votes  Int
  viewer String
  movies MovieRating[]

  @@schema("movie_world")
}

model Movie {
  id          Int                @id @default(autoincrement())
  title       String
  year        Int
  description String
  runtime     Int
  country     String
  budget      Float
  directorId  Int
  poster      String?
  director    Director           @relation(fields: [directorId], references: [id])
  actors      MovieActor[]
  genres      MovieGenre[]
  ratings     MovieRating[]
  views       MovieViewHistory[]

  @@index([directorId], map: "idx_movie_director_id")
  @@index([title], map: "idx_movie_title")
  @@index([year], map: "idx_movie_year")
  @@schema("movie_world")
}

model MovieActor {
  id      Int   @id @default(autoincrement())
  movieId Int
  actorId Int
  actor   Actor @relation(fields: [actorId], references: [id])
  movie   Movie @relation(fields: [movieId], references: [id])

  @@schema("movie_world")
}

model MovieGenre {
  id      Int   @id @default(autoincrement())
  movieId Int
  genreId Int
  genre   Genre @relation(fields: [genreId], references: [id])
  movie   Movie @relation(fields: [movieId], references: [id])

  @@schema("movie_world")
}

model MovieRating {
  id       Int    @id @default(autoincrement())
  movieId  Int
  ratingId Int
  movie    Movie  @relation(fields: [movieId], references: [id])
  rating   Rating @relation(fields: [ratingId], references: [id])

  @@schema("movie_world")
}

model MovieViewHistory {
  id       Int       @id @default(autoincrement())
  userId   Int
  movieId  Int
  viewedAt DateTime? @default(now()) @db.Timestamp(6)
  movie    Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_movie_view_movie")
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_movie_view_user")

  @@schema("movie_world")
}

model movie_delete_log {
  id          Int       @id @default(autoincrement())
  movie_id    Int?
  movie_title String?
  deleted_at  DateTime? @default(now()) @db.Timestamp(6)

  @@schema("movie_world")
}

model movie_log {
  id          Int       @id @default(autoincrement())
  movie_title String?
  movie_year  Int?
  created_at  DateTime? @default(now()) @db.Timestamp(6)

  @@schema("movie_world")
}
